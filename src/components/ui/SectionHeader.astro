---
interface Props {
  num: string;
  title: string;
  jpTitle: string;
  desc?: string;
}
const { num, title, jpTitle, desc } = Astro.props;
---

<header class="section-header">
  <div class="mono accent">— SECTION {num}</div>
  <h2>
    {title}
    <span>/ {jpTitle}</span>
  </h2>
  {desc && <p>{desc}</p>}
</header>

<style>
  .section-header {
    margin-bottom: 48px;
    max-width: 900px;
  }
  .mono {
    font-family: var(--font-brand-en);
    font-size: 11px;
    letter-spacing: 0.3em;
    margin-bottom: 16px;
    font-weight: 600;
  }
  .accent {
    color: var(--accent);
  }
  h2 {
    font-family: var(--font-brand-display);
    font-weight: 700;
    font-size: clamp(44px, 6.5vw, 88px);
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  h2 span {
    font-family: var(--font-brand-heading);
    font-style: normal;
    color: var(--accent);
  }
  p {
    font-family: var(--font-brand-body);
    font-size: 15px;
    color: var(--text-secondary);
    margin-top: 20px;
    line-height: 1.9;
    max-width: 600px;
  }
</style>
