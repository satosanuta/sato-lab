---
import '@/styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = '砂糖さんの実験室 / sato-lab',
  description = '日本のWebサイトで使われるフォントと演出のリファレンス。触って確認できるショーケース。',
  ogImage = '/og-image.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e0e10" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Google Fonts: preconnect + async-safe stylesheet -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Shippori+Mincho:wght@700;900&family=Zen+Old+Mincho:wght@700;900&family=BIZ+UDPGothic:wght@400;700&family=Dela+Gothic+One&family=Yusei+Magic&family=Klee+One:wght@600&family=RocknRoll+One&family=Inter:wght@400;500;700&family=Montserrat:wght@500;700;900&family=Poppins:wght@400;500;700&family=Playfair+Display:ital,wght@0,700;1,400;1,700&family=DM+Serif+Display:ital@0;1&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;700&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="sato-lab / 砂糖さんの実験室" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="sato-lab / 砂糖さんの実験室 — Typography × Motion Reference"
    />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: '砂糖さんの実験室 / sato-lab',
        description,
        url: Astro.site?.toString(),
        inLanguage: 'ja-JP',
      })}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
