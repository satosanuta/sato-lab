---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopNav from '@/components/ui/TopNav.astro';

const title = 'Branding / 砂糖さんの実験室';
const description =
  '砂糖さんブランドのコア・キャラクター・表現設計。カラー、フォント、接点、運用ガイドラインの完全版。';
---

<BaseLayout title={title} description={description}>
  <TopNav current="branding" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-tag">— SECTION 03</div>
    <h1>
      Branding /<br />
      <span>セルフブランディング</span>
    </h1>
    <p class="hero-sub">
      Self-Branding Reference — Core × Character × Expression × Originality × Story
    </p>
    <div class="hero-stats">
      <div class="hero-stat"><strong>3</strong>LAYERS</div>
      <div class="hero-stat"><strong>5</strong>TOUCHPOINTS</div>
      <div class="hero-stat"><strong>4</strong>CROSSES</div>
      <div class="hero-stat"><strong>5</strong>FONTS</div>
    </div>
    <div class="scroll-hint" aria-hidden="true">SCROLL ↓</div>
  </section>

  <!-- CORE LAYER -->
  <section class="section" id="core">
    <div class="section-tag">— 01 / CORE LAYER</div>
    <h2>コア層</h2>
    <p class="section-desc">
      砂糖さんの活動すべての根幹。ここがブレると、キャラクターも表現も崩れる。
    </p>

    <div class="core-statement">
      <p>
        自分が愛するファンタジーの世界で、仕事を頑張る人たちをほっとさせて、また前を向いて送り出す場所をつくる。
      </p>
    </div>

    <div class="core-grid">
      <div class="core-card">
        <div class="core-card-label">WHY / なぜやるか</div>
        <h3>好きなものが、人の役に立つ形になった</h3>
        <p>
          自分自身がファンタジーを愛していて、かつ身近に癒したい人がいる。与えるために学んだのではなく、もともと好きなものが使命になった。作られた使命感ではなく、自然に滲み出るもの。
        </p>
      </div>
      <div class="core-card">
        <div class="core-card-label">WHO / 誰に届けるか</div>
        <h3>30代の、仕事を頑張る世代</h3>
        <p>
          日々リアリティの中で戦っている人たち。心の拠り所となるファンタジーな場所を必要としている人たち。
        </p>
      </div>
      <div class="core-card">
        <div class="core-card-label">WHAT / 何を届けるか</div>
        <h3>ほっとさせて、送り出す場所</h3>
        <p>
          まず「ほっとする」逃げ場機能。そして「また頑張れる」充電基地機能。コンテンツではなく「場所」をつくる。入り口はやさしく、出口は前向き。
        </p>
      </div>
    </div>
  </section>

  <!-- CHARACTER LAYER -->
  <section class="section" id="character">
    <div class="section-tag">— 02 / CHARACTER LAYER</div>
    <h2>キャラクター層</h2>
    <p class="section-desc">
      コアを体現する人格。砂糖さん自身をベースに、何を出して・出さないかをチューニングする。乖離しすぎない、長く続けられる設計。
    </p>

    <div class="char-grid">
      <div class="char-card">
        <h3>人格・性格</h3>
        <ul>
          <li>穏やかだけど芯がある</li>
          <li>一人でも世界を楽しめる冒険者</li>
          <li>仲間がいると何をやっても楽しい</li>
          <li>清楚に見えるが、怒ると怖い</li>
          <li>INFP / INTP を行き来する（理想と構造の両立）</li>
        </ul>
      </div>
      <div class="char-card">
        <h3>姿勢</h3>
        <ul>
          <li>強制しない。「来い」とは言わない</li>
          <li>でも来てくれたなら、その時間は本気で大切にする</li>
          <li>嘘はつかない</li>
          <li>「一緒にいること」自体が価値</li>
          <li>強制ゼロ、感謝100</li>
        </ul>
      </div>
      <div class="char-card">
        <h3>ブランド構造</h3>
        <ul>
          <li>「異世界冒険者」が本体</li>
          <li>全活動は冒険者のスキルとして統合される</li>
          <li>歌 → 吟遊詩人スキル</li>
          <li>ゲーム → 冒険そのもの</li>
          <li>MIX → 錬金術・調合スキル</li>
          <li>技術 → 魔道具製作スキル</li>
        </ul>
      </div>
      <div class="char-card">
        <h3>人間味</h3>
        <ul>
          <li>頑張り屋だけど時間にルーズ</li>
          <li>夜更かし・夜行性の冒険者</li>
          <li>隠さず世界観に組み込む</li>
          <li>欠点を味にする</li>
        </ul>
      </div>
      <div class="char-card">
        <h3>出す／出さない</h3>
        <ul>
          <li>前面に出す：世界観 → スキルで体現</li>
          <li>自然に出す：仕事・技術・趣味・ネガティブな感情</li>
          <li>非公開：恋愛関連（ただし否定はしない）</li>
          <li>方針：「言わないけど嘘はつかない」</li>
        </ul>
      </div>
      <div class="char-card">
        <h3>大事にしている一線</h3>
        <ul>
          <li>「一緒にいること」への敬意を持ってほしい</li>
          <li>無理強いはしない</li>
          <li>だからこそ居てくれる人は尊い</li>
          <li>この一線を越えると芯が出る</li>
        </ul>
      </div>
    </div>

    <h3 class="sub-heading">二面性</h3>
    <div class="duality">
      <div class="duality-side warm">
        <div class="duality-label">WARM SIDE</div>
        <h3>穏やか・安心</h3>
        <p>
          配信で出る面。ほっとする空気。男性リスナーが反応しやすい。一緒にいるだけで安心できる存在。
        </p>
      </div>
      <div class="duality-side cool">
        <div class="duality-label">COOL SIDE</div>
        <h3>カッコイイ・芯がある</h3>
        <p>
          歌で出る面。カッコイイ系の歌ってみた。女性リスナーも反応する。惚れる、という感覚に近い。
        </p>
      </div>
    </div>
  </section>

  <!-- EXPRESSION LAYER -->
  <section class="section" id="expression">
    <div class="section-tag">— 03 / EXPRESSION LAYER</div>
    <h2>表現層</h2>
    <p class="section-desc">コアとキャラクターを、視覚・聴覚・体験として届ける設計。</p>

    <h3 class="sub-heading">COLOR SYSTEM</h3>
    <p class="note-text">
      キーカラー：オレンジ。砂糖さん本人を表す色。日本時間（JST）に基づいて、朝・昼と夜の2モードが自動で切り替わる（手動切替も可）。
    </p>

    <div class="color-system">
      <div class="color-mode">
        <div class="color-mode-label">
          夜モード — 焚き火の灯り
          <span class="mode-time">JST 18:00–04:59</span>
        </div>
        <div class="color-bar">
          <div class="color-seg" style="flex: 70; background: #0a0e1a; color: #ffffff">
            <span class="seg-pct">70%</span>
            <span class="seg-name">ダーク青</span>
            <code class="seg-hex">#0a0e1a</code>
          </div>
          <div class="color-seg" style="flex: 15; background: #1a1a3e; color: #ffffff">
            <span class="seg-pct">15%</span>
            <span class="seg-name">紫</span>
            <code class="seg-hex">#1a1a3e</code>
          </div>
          <div class="color-seg" style="flex: 10; background: #2d2b55; color: #ffffff">
            <span class="seg-pct">10%</span>
            <span class="seg-name">藍</span>
            <code class="seg-hex">#2d2b55</code>
          </div>
          <div class="color-seg" style="flex: 5; background: #e8751a; color: #ffffff">
            <span class="seg-pct">5%</span>
            <span class="seg-name">橙</span>
            <code class="seg-hex">#e8751a</code>
          </div>
        </div>
      </div>
      <div class="color-mode">
        <div class="color-mode-label">
          朝・昼モード — 冒険の出発
          <span class="mode-time">JST 05:00–17:59</span>
        </div>
        <div class="color-bar">
          <div class="color-seg" style="flex: 70; background: #f5f0e8; color: #1a1a2e">
            <span class="seg-pct">70%</span>
            <span class="seg-name">ベージュ</span>
            <code class="seg-hex">#f5f0e8</code>
          </div>
          <div class="color-seg" style="flex: 15; background: #e8e0f0; color: #1a1a2e">
            <span class="seg-pct">15%</span>
            <span class="seg-name">ラベンダー</span>
            <code class="seg-hex">#e8e0f0</code>
          </div>
          <div class="color-seg" style="flex: 10; background: #d5cfe0; color: #1a1a2e">
            <span class="seg-pct">10%</span>
            <span class="seg-name">淡藍</span>
            <code class="seg-hex">#d5cfe0</code>
          </div>
          <div class="color-seg" style="flex: 5; background: #d4711a; color: #ffffff">
            <span class="seg-pct">5%</span>
            <span class="seg-name">橙</span>
            <code class="seg-hex">#d4711a</code>
          </div>
        </div>
      </div>
      <div class="color-detail">
        <div class="color-chip">
          <span class="color-dot" style="background: #e8751a" aria-hidden="true"></span>
          <span>Orange<br />#e8751a</span>
        </div>
        <div class="color-chip">
          <span class="color-dot" style="background: #f5a623" aria-hidden="true"></span>
          <span>Gold<br />#f5a623</span>
        </div>
        <div class="color-chip">
          <span class="color-dot" style="background: #0a0e1a" aria-hidden="true"></span>
          <span>Dark Blue<br />#0a0e1a</span>
        </div>
        <div class="color-chip">
          <span class="color-dot" style="background: #1a1a3e" aria-hidden="true"></span>
          <span>Purple<br />#1a1a3e</span>
        </div>
        <div class="color-chip">
          <span class="color-dot" style="background: #2d2b55" aria-hidden="true"></span>
          <span>Indigo<br />#2d2b55</span>
        </div>
        <div class="color-chip">
          <span
            class="color-dot"
            style="background: #f5f0e8; border: 1px solid var(--border)"
            aria-hidden="true"></span>
          <span>Warm White<br />#f5f0e8</span>
        </div>
        <div class="color-chip">
          <span
            class="color-dot"
            style="background: #e8e0f0; border: 1px solid var(--border)"
            aria-hidden="true"></span>
          <span>Lavender<br />#e8e0f0</span>
        </div>
      </div>
    </div>

    <h3 class="sub-heading">FONT SYSTEM</h3>
    <table class="font-table">
      <thead>
        <tr><th>FONT</th><th>ROLE</th><th>SAMPLE</th></tr>
      </thead>
      <tbody>
        <tr>
          <td>
            <span class="font-name f-heading">BIZ UDPGothic</span>
          </td>
          <td><span class="font-role primary">JP 見出し</span></td>
          <td>
            <span class="font-sample f-heading">冒険者ギルドへようこそ！</span>
          </td>
        </tr>
        <tr>
          <td>
            <span class="font-name f-body">Noto Sans JP</span>
          </td>
          <td><span class="font-role secondary">JP 本文</span></td>
          <td>
            <span class="font-sample f-body">仲間と過ごす時間が、明日への力になる。</span>
          </td>
        </tr>
        <tr>
          <td>
            <span class="font-name f-accent">源柔ゴシック</span><br />
            <span class="font-note">Web: Zen Maru Gothic</span>
          </td>
          <td><span class="font-role tertiary">JP アクセント</span></td>
          <td>
            <span class="font-sample f-accent">ちょっと異質な温かみを出したい時に</span>
          </td>
        </tr>
        <tr>
          <td>
            <span class="font-name f-inter">Inter</span>
          </td>
          <td><span class="font-role secondary">EN 本文・UI</span></td>
          <td>
            <span class="font-sample f-inter">A place where you can recharge.</span>
          </td>
        </tr>
        <tr>
          <td>
            <span class="font-name f-shippori">Shippori Mincho</span>
          </td>
          <td><span class="font-role primary">EN 大見出し</span></td>
          <td>
            <span class="font-sample f-shippori">Adventurer's Guild</span>
          </td>
        </tr>
      </tbody>
    </table>

    <h3 class="sub-heading">SITE DESIGN — 二面演出</h3>
    <p class="note-text">時間帯で自動切替。同じ世界の違う時間を体験する設計。</p>

    <div class="site-modes">
      <div class="site-mode dark">
        <h3>夜モード</h3>
        <div class="site-mode-meta">焚き火のそばで一息</div>
        <p>
          カスタムカーソル＋パーティクル演出。光の粒子・魔法の軌跡。暗闇の中で光るから美しい。ファンタジー色強め、没入感重視。歌を聴く人が好きになる世界観。
        </p>
      </div>
      <div class="site-mode light">
        <h3>朝・昼モード</h3>
        <div class="site-mode-meta">さあ今日も冒険だ</div>
        <p>
          自然の動き（風に舞う葉・揺れる草花・漂う雲）。明るい背景で見やすさ優先。テキスト・コンテンツが主役。配信を見る人が入りやすい雰囲気。元気・出発の空気。
        </p>
      </div>
    </div>
  </section>

  <!-- TOUCHPOINTS -->
  <section class="section" id="touchpoints">
    <div class="section-tag">— 04 / TOUCHPOINTS</div>
    <h2>接点設計</h2>
    <p class="section-desc">リスナーが砂糖さんに触れるすべての場所と、その役割。</p>

    <div class="tp-grid">
      <div class="tp-card">
        <div class="tp-card-head">
          <h3>satosan.live</h3>
          <span class="tp-card-num">01</span>
        </div>
        <div class="tp-card-role">世界への入口・自己紹介</div>
        <p>
          砂糖さんの世界観を体験する場所。時間帯で昼夜が切り替わり、異世界の時間が流れている演出。すべての接点の中心。
        </p>
      </div>
      <div class="tp-card">
        <div class="tp-card-head">
          <h3>YouTube</h3>
          <span class="tp-card-num">02</span>
        </div>
        <div class="tp-card-role">メインコンテンツ</div>
        <p>
          歌ってみた・歌枠・ゲーム配信。一番のコンテンツ。サムネはオレンジ文字＋BIZ
          UDPGothic（Canvaでは源柔ゴシック）＋砂糖さんが必ずいるルール。
        </p>
      </div>
      <div class="tp-card">
        <div class="tp-card-head">
          <h3>X (@satosan_uta)</h3>
          <span class="tp-card-num">03</span>
        </div>
        <div class="tp-card-role">告知・日常の浸透</div>
        <p>
          告知と日常会話で隙間時間に浸透する。ヘッダーはファンタジー世界にいる砂糖さんの1枚絵。対応済み。
        </p>
      </div>
      <div class="tp-card">
        <div class="tp-card-head">
          <h3>Discord (リ砂ー)</h3>
          <span class="tp-card-num">04</span>
        </div>
        <div class="tp-card-role">仲間との交流</div>
        <p>
          冒険者たちのたまり場。歌の話もゲームの話も自然に混ざる場所。プラットフォーム制約あり、現状維持でOK。
        </p>
      </div>
      <div class="tp-card">
        <div class="tp-card-head">
          <h3>BOOTH</h3>
          <span class="tp-card-num">05</span>
        </div>
        <div class="tp-card-role">身近に置いてもらう</div>
        <p>
          冒険の記念品。ヘッダー・背景をダーク系に、ボタン色をオレンジに変更。サイト夜モードと同じ空気感に寄せる。
        </p>
      </div>
    </div>

    <h3 class="sub-heading">LISTENER JOURNEY / リスナーの旅路</h3>
    <ol class="journey">
      <li class="journey-step">
        <div class="journey-label">STEP 01</div>
        <div class="journey-name">出会う</div>
        <div class="journey-desc">X / 検索 / おすすめ</div>
      </li>
      <li class="journey-step">
        <div class="journey-label">STEP 02</div>
        <div class="journey-name">世界を知る</div>
        <div class="journey-desc">サイト</div>
      </li>
      <li class="journey-step">
        <div class="journey-label">STEP 03</div>
        <div class="journey-name">体験する</div>
        <div class="journey-desc">YouTube</div>
      </li>
      <li class="journey-step">
        <div class="journey-label">STEP 04</div>
        <div class="journey-name">仲間になる</div>
        <div class="journey-desc">Discord</div>
      </li>
      <li class="journey-step">
        <div class="journey-label">STEP 05</div>
        <div class="journey-name">持ち帰る</div>
        <div class="journey-desc">BOOTH</div>
      </li>
    </ol>
  </section>

  <!-- ORIGINALITY -->
  <section class="section" id="originality">
    <div class="section-tag">— 05 / ORIGINALITY</div>
    <h2>オリジナリティ</h2>
    <p class="section-desc">砂糖さんの要素は単体では珍しくない。掛け合わせが唯一無二にする。</p>

    <div class="orig-catchcopy">
      <p>物語の世界を、一緒に冒険しよう</p>
    </div>

    <div class="orig-grid">
      <div class="orig-card">
        <div class="orig-card-num">CROSS 01</div>
        <div class="orig-formula">本業 × 活動</div>
        <h3>社会人の説得力</h3>
        <p>
          ITマネージャーとして組織を動かす仕事をしながら表現活動をしている。「社会人の苦労」が本物だからこそ、「充電基地」に説得力がある。
        </p>
      </div>
      <div class="orig-card">
        <div class="orig-card-num">CROSS 02</div>
        <div class="orig-formula">作る × 届ける</div>
        <h3>全部自分で作れる</h3>
        <p>
          歌・MIX・サイト・ツール・配信環境。コンテンツを作るだけでなく、届ける仕組みも自分で構築できる。冒険者のスキルが本物。
        </p>
      </div>
      <div class="orig-card">
        <div class="orig-card-num">CROSS 03</div>
        <div class="orig-formula">世界観 × 場の設計</div>
        <h3>大人のギルド</h3>
        <p>
          ファンタジーは「逃避」ではなく「回復して戻る場所」。ギルドの掟（礼節）がある＝安全な場所。ちゃんとした大人のファンタジー充電基地。
        </p>
      </div>
      <div class="orig-card">
        <div class="orig-card-num">CROSS 04</div>
        <div class="orig-formula">探求 × 共有</div>
        <h3>一緒に世界を味わう</h3>
        <p>
          歌やゲームの世界観をみんなと一緒に深く理解し、楽しみたい。コンテンツを「提供」するのではなく「一緒に旅する」。これが活動の核。
        </p>
      </div>
    </div>
  </section>

  <!-- STORY -->
  <section class="section" id="story">
    <div class="section-tag">— 06 / STORY</div>
    <h2>ブランドストーリー</h2>
    <p class="section-desc">なぜこの掛け合わせになったか。砂糖さん自身の物語。</p>

    <ol class="story-timeline">
      <li class="story-phase">
        <span class="story-dot" aria-hidden="true"></span>
        <div class="story-label">ORIGIN / 起源</div>
        <h3>兄弟から教わった「好き」</h3>
        <p>
          歌もゲームも、兄弟から教わった好きなこと。誰かのためではなく、ただ純粋に好きだったものが始まり。
        </p>
      </li>
      <li class="story-phase">
        <span class="story-dot" aria-hidden="true"></span>
        <div class="story-label">TURNING POINT / 転機</div>
        <h3>世界が止まって、自分が動いた</h3>
        <p>
          コロナ禍で家にいる時間が増え、「いよいよやってみよう」と動き出した。最初はVTuberではなかった。新しい姿になるタイミングで振り返ったら、自分はずっと「世界観を大事にする作品と出会い続けてきた人」だった。冒険者という軸は、作ったのではなく発見した。
        </p>
      </li>
      <li class="story-phase">
        <span class="story-dot" aria-hidden="true"></span>
        <div class="story-label">BELIEF / 信念</div>
        <h3>正直な一言が、存在意義になる</h3>
        <p>
          表面的な「可愛い」は響かない。「力になった」という正直な言葉だけが、自分の存在意義を確かめてくれる。それがある限り続けられる。
        </p>
      </li>
