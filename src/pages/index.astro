---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopNav from '@/components/ui/TopNav.astro';
import Hero from '@/components/ui/Hero';
import { motionDemos } from '@/data/motion';
import { jpFonts, enFonts } from '@/data/fonts';

const immersiveDemos = motionDemos.filter((d) => d.trend === '没入型');
const otherDemos = motionDemos.filter((d) => d.trend !== '没入型');
---

<BaseLayout>
  <TopNav current="home" />
  <Hero client:load />

  <section class="intro">
    <div class="label">— INDEX / 索引</div>
    <h2>
      砂糖さんの<br />
      <span>実験場</span>へ、ようこそ
    </h2>
    <p class="desc">
      フォント・演出・ブランディング。異世界冒険者としての活動を支える仕組みを、<br />
      ひとつずつ形にして残していく場所。
    </p>
  </section>

  <section class="grid-section">
    <div class="col">
      <div class="col-head">
        <div class="mono">03 / Branding</div>
        <h3>ブランディング</h3>
        <div class="count">3 layers</div>
      </div>
      <a href="/branding/" class="big-link">
        コア × キャラクター × 表現<span>→</span>
      </a>
      <ul class="bullet-list">
        <li>活動の根幹となる3層構造</li>
        <li>色・フォント・接点設計</li>
        <li>運用ガイドライン</li>
      </ul>
    </div>

    <div class="col">
      <div class="col-head">
        <div class="mono">01 / Typography</div>
        <h3>書体</h3>
        <div class="count">{jpFonts.length + enFonts.length} typefaces</div>
      </div>
      <a href="/fonts/" class="big-link">
        フォント一覧へ<span>→</span>
      </a>
      <ul class="font-list">
        {
          jpFonts
            .slice(0, 3)
            .map((f) => (
              <li style={`font-family: ${f.family}; font-weight: ${f.weight};`}>{f.name}</li>
            ))
        }
        {
          enFonts
            .slice(0, 2)
            .map((f) => (
              <li style={`font-family: ${f.family}; font-weight: ${f.weight};`}>{f.name}</li>
            ))
        }
        <li class="more">ほか {jpFonts.length + enFonts.length - 5} 書体</li>
      </ul>
    </div>

    <div class="col">
      <div class="col-head">
        <div class="mono">02 / Motion</div>
        <h3>演出</h3>
        <div class="count">{motionDemos.length} demos</div>
      </div>
      <a href="/motion/" class="big-link">
        演出一覧へ<span>→</span>
      </a>
      <div class="motion-groups">
        <div class="motion-group featured">
          <div class="group-label">没入型 · {immersiveDemos.length}</div>
          <ul>
            {
              immersiveDemos.slice(0, 4).map((d) => (
                <li>
                  <a href={`/motion/${d.slug}/`}>{d.title}</a>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="motion-group">
          <div class="group-label">その他 · {otherDemos.length}</div>
          <ul>
            {
              otherDemos.slice(0, 3).map((d) => (
                <li>
                  <a href={`/motion/${d.slug}/`}>{d.title}</a>
                </li>
              ))
            }
            <li class="more">ほか {otherDemos.length - 3} 種</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="footer-title">
      砂糖さんの<br />
      <span>実験は</span>、<br />
      <em>続いていく。</em>
    </div>
    <div class="footer-meta">
      <span>— SATO-LAB</span>
      <span>BRANDING × TYPOGRAPHY × MOTION / 2025—</span>
    </div>
  </footer>
</BaseLayout>

<style>
  .intro {
    padding: 80px 5vw 40px;
  }
  .label {
    font-family: var(--font-brand-en);
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--accent);
    margin-bottom: 16px;
    font-weight: 600;
  }
  h2 {
    font-family: var(--font-brand-heading);
    font-weight: 700;
    font-size: clamp(36px, 6vw, 80px);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  h2 span {
    color: var(--accent);
  }
  .desc {
    font-family: var(--font-brand-body);
    font-size: 15px;
    line-height: 1.9;
    color: var(--text-secondary);
    margin-top: 24px;
    max-width: 560px;
  }

  .grid-section {
    padding: 40px 5vw 120px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }
  @media (max-width: 1000px) {
    .grid-section {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 680px) {
    .grid-section {
      grid-template-columns: 1fr;
    }
  }
  .col {
    background: var(--bg);
    padding: 48px 36px;
  }
  .col-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .mono {
    font-family: var(--font-brand-en);
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--accent);
    font-weight: 600;
  }
  .col h3 {
    font-family: var(--font-brand-heading);
    font-weight: 700;
    font-size: 36px;
    margin: 0;
    color: var(--text);
  }
  .count {
    font-family: var(--font-brand-en);
    font-size: 10px;
    color: var(--text-tertiary);
    letter-spacing: 0.2em;
    margin-left: auto;
  }
  .big-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    font-family: var(--font-brand-heading);
    font-size: 20px;
    font-weight: 700;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    color: var(--text);
    transition: color 0.3s;
  }
  .big-link span {
    font-family: var(--font-brand-en);
    font-size: 18px;
    color: var(--accent);
    transition: transform 0.3s;
  }
  .big-link:hover {
    color: var(--accent);
  }
  .big-link:hover span {
    transform: translateX(8px);
  }

  .bullet-list,
  .font-list {
    list-style: none;
    padding: 28px 0 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .bullet-list li {
    font-family: var(--font-brand-body);
    font-size: 14px;
    color: var(--text-secondary);
    padding-left: 16px;
    position: relative;
    line-height: 1.8;
  }
  .bullet-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .font-list li {
    font-size: 20px;
    color: var(--text);
  }
  .font-list .more {
    font-family: var(--font-brand-en) !important;
    font-weight: 400 !important;
    font-size: 11px !important;
    color: var(--text-tertiary);
    letter-spacing: 0.2em;
    padding-top: 8px;
  }

  .motion-groups {
    padding: 28px 0 0;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .group-label {
    font-family: var(--font-brand-en);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--text-tertiary);
    margin-bottom: 12px;
  }
  .motion-group.featured .group-label {
    color: var(--accent);
  }
  .motion-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .motion-group li a {
    font-family: var(--font-brand-body);
    font-size: 14px;
    color: var(--text);
    padding: 6px 0;
    display: block;
    border-bottom: 1px solid var(--border);
    transition:
      color 0.2s,
      padding-left 0.2s;
  }
  .motion-group li a:hover {
    color: var(--accent);
    padding-left: 8px;
  }
  .motion-group .more {
    font-family: var(--font-brand-en);
    font-size: 11px;
    color: var(--text-tertiary);
    letter-spacing: 0.2em;
    padding-top: 8px;
  }

  .site-footer {
    background: var(--bg);
    padding: 80px 5vw 48px;
    border-top: 1px solid var(--border);
  }
  .footer-title {
    font-family: var(--font-brand-heading);
    font-size: clamp(40px, 7vw, 88px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    max-width: 900px;
    color: var(--text);
  }
  .footer-title span {
    color: var(--accent);
  }
  .footer-title em {
    font-family: var(--font-brand-display);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }
  .footer-meta {
    margin-top: 64px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-brand-en);
    font-size: 11px;
    color: var(--text-tertiary);
    letter-spacing: 0.2em;
    flex-wrap: wrap;
    gap: 24px;
  }
</style>
