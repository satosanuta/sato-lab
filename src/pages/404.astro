---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopNav from '@/components/ui/TopNav.astro';
---

<BaseLayout
  title="Not Found / 砂糖さんの実験室"
  description="お探しのページは見つかりませんでした。"
>
  <TopNav current="home" />

  <section class="wrap">
    <div class="mono">— ERROR / 404</div>
    <h1>
      迷子に、<br />
      <span>なりましたか。</span>
    </h1>
    <p class="desc">
      お探しのページは、引っ越した、<br />
      あるいは最初から存在しなかったかもしれません。
    </p>

    <div class="actions">
      <a href="/" class="primary">
        <span class="label">索引へ戻る</span>
        <span class="arrow">→</span>
      </a>
      <div class="secondary">
        <a href="/fonts/">01 / Fonts</a>
        <a href="/motion/">02 / Motion</a>
      </div>
    </div>

    <div class="meta">
      <span>— SATO-LAB</span>
      <span>404 NOT FOUND</span>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    min-height: 80vh;
    padding: 80px 5vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--ink);
    color: var(--paper);
  }
  .mono {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--accent);
    margin-bottom: 24px;
  }
  h1 {
    font-family: var(--font-jp-mincho);
    font-weight: 900;
    font-size: clamp(48px, 9vw, 120px);
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  h1 span {
    color: var(--accent);
  }
  .desc {
    font-family: var(--font-jp-gothic);
    font-size: 16px;
    line-height: 1.9;
    color: var(--muted);
    margin-top: 32px;
    max-width: 540px;
  }
  .actions {
    margin-top: 64px;
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .primary {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 20px 32px;
    border: 1px solid var(--accent);
    color: var(--paper);
    font-family: var(--font-jp-mincho);
    font-size: 20px;
    font-weight: 700;
    transition:
      background 0.25s,
      color 0.25s;
  }
  .primary:hover {
    background: var(--accent);
    color: var(--ink);
  }
  .primary .arrow {
    font-family: var(--font-mono);
    transition: transform 0.25s;
  }
  .primary:hover .arrow {
    transform: translateX(6px);
  }
  .secondary {
    display: flex;
    gap: 28px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.25em;
  }
  .secondary a {
    color: var(--muted);
    padding: 8px 0;
    border-bottom: 1px solid transparent;
    transition:
      color 0.2s,
      border-color 0.2s;
  }
  .secondary a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .meta {
    margin-top: 96px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--muted);
    flex-wrap: wrap;
    gap: 16px;
  }
</style>
