---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopNav from '@/components/ui/TopNav.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { motionDemos, countsByTrend } from '@/data/motion';

const byCategory = motionDemos.reduce(
  (acc, d) => {
    (acc[d.category] ||= []).push(d);
    return acc;
  },
  {} as Record<string, typeof motionDemos>,
);

const categoryLabels: Record<string, { en: string; jp: string }> = {
  immersive: { en: 'Immersive', jp: '没入型' },
  text: { en: 'Text', jp: 'テキスト' },
  interaction: { en: 'Interaction', jp: 'インタラクション' },
  visual: { en: 'Visual', jp: 'ビジュアル' },
  layout: { en: 'Layout', jp: 'レイアウト' },
};

const categoryOrder = ['immersive', 'text', 'interaction', 'visual', 'layout'];
---

<BaseLayout title="Motion / 砂糖さんの実験室">
  <TopNav current="motion" />

  <section class="wrap">
    <SectionHeader
      num="02"
      title="Motion"
      jpTitle="演出"
      desc="日本のWebサイトで2024-2025年に主流・最前線となっている演出。個別のデモページで、実装の手触りを確認できます。"
    />

    <div class="stats">
      <div class="stat">
        <div class="n">{motionDemos.length}</div>
        <div class="lbl">DEMOS</div>
      </div>
      <div class="stat">
        <div class="n">{countsByTrend['没入型'] ?? 0}</div>
        <div class="lbl">IMMERSIVE</div>
      </div>
      <div class="stat">
        <div class="n">{countsByTrend['定番'] ?? 0}</div>
        <div class="lbl">DEFAULT</div>
      </div>
      <div class="stat">
        <div class="n">{countsByTrend['最先端'] ?? 0}</div>
        <div class="lbl">LATEST</div>
      </div>
    </div>

    {
      categoryOrder.map(
        (cat) =>
          byCategory[cat] && (
            <div class="cat">
              <div class="cat-head">
                <div class="cat-num">{categoryLabels[cat]?.en}</div>
                <h3>{categoryLabels[cat]?.jp}</h3>
                <div class="cat-count">{byCategory[cat]!.length}</div>
              </div>
              <div class="demos">
                {byCategory[cat]!.map((d) => (
                  <a href={`/motion/${d.slug}/`} class="demo-link">
                    <div class="trend-tag" data-trend={d.trend}>
                      {d.trend}
                    </div>
                    <h4>{d.title}</h4>
                    <p>{d.desc}</p>
                    <div class="tech">{d.tech}</div>
                  </a>
                ))}
              </div>
            </div>
          ),
      )
    }
  </section>

  <footer class="mini-footer">
    <a href="/">← 索引に戻る</a>
    <a href="/fonts/">フォント一覧へ →</a>
  </footer>
</BaseLayout>

<style>
  .wrap {
    background: var(--bg);
    color: var(--text);
    padding: 80px 5vw;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    background: var(--border);
    margin-bottom: 80px;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .stat {
    background: var(--bg-elevated);
    padding: 32px 24px;
  }
  .stat .n {
    font-family: var(--font-brand-display);
    font-size: 64px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }
  .stat .lbl {
    font-family: var(--font-brand-en);
    font-size: 10px;
    color: var(--text-tertiary);
    letter-spacing: 0.2em;
    margin-top: 8px;
  }

  .cat {
    margin-bottom: 72px;
  }
  .cat-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .cat-num {
    font-family: var(--font-brand-display);
    font-style: italic;
    font-size: 28px;
    color: var(--accent-gold);
  }
  .cat h3 {
    font-family: var(--font-brand-heading);
    font-weight: 700;
    font-size: 30px;
    margin: 0;
    color: var(--text);
  }
  .cat-count {
    font-family: var(--font-brand-en);
    font-size: 10px;
    color: var(--text-tertiary);
    letter-spacing: 0.2em;
    margin-left: auto;
  }

  .demos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }
  .demo-link {
    display: block;
    padding: 24px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    transition:
      background 0.2s,
      border-color 0.2s,
      transform 0.2s;
  }
  .demo-link:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .trend-tag {
    display: inline-block;
    font-family: var(--font-brand-en);
    font-size: 9px;
    letter-spacing: 0.2em;
    padding: 3px 9px;
    border: 1px solid;
    border-radius: 100px;
    margin-bottom: 12px;
    font-weight: 600;
  }
  .trend-tag[data-trend='没入型'] {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .trend-tag[data-trend='最先端'] {
    color: var(--purple);
    border-color: color-mix(in srgb, var(--purple) 40%, transparent);
    background: color-mix(in srgb, var(--purple) 8%, transparent);
  }
  .trend-tag[data-trend='定番'] {
    color: var(--text-tertiary);
    border-color: var(--border);
  }
  .demo-link h4 {
    font-family: var(--font-brand-heading);
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--text);
  }
  .demo-link p {
    font-family: var(--font-brand-body);
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0 0 16px;
    line-height: 1.7;
  }
  .tech {
    font-family: var(--font-brand-en);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.15em;
    font-weight: 600;
  }

  .mini-footer {
    padding: 32px 5vw;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-brand-en);
    font-size: 11px;
    letter-spacing: 0.2em;
    border-top: 1px solid var(--border);
  }
  .mini-footer a {
    color: var(--text);
    transition: color 0.2s;
  }
  .mini-footer a:hover {
    color: var(--accent);
  }
</style>
